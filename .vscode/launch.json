{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🐛 GDB Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/data_structures",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "🔨 Make: Build",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "🏃 Run Without Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/data_structures",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "🔨 Make: Build",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}
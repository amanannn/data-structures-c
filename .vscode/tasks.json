{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🔨 Make: Build",
            "type": "shell",
            "command": "make",
            "args": ["-j4"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "🚀 Make: Run",
            "type": "shell",
            "command": "make",
            "args": ["run"],
            "group": "test",
            "dependsOn": "🔨 Make: Build",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "🧹 Make: Clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "🔄 Make: Rebuild",
            "type": "shell",
            "command": "make",
            "args": ["rebuild"],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}